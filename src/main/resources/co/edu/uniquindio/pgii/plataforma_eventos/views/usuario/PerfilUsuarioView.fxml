<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.ColumnConstraints?>

<BorderPane prefWidth="860.0" prefHeight="580.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.pgii.plataforma_eventos.ui.controllers.usuario.PerfilUsuarioController">

    <!-- ═══ ENCABEZADO ═══ -->
    <top>
        <VBox spacing="8.0" style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="14.0" right="16.0" bottom="14.0" left="16.0"/></padding>

            <HBox spacing="8.0" alignment="CENTER_LEFT">
                <Button text="Eventos" onAction="#onNavEventos"/>
                <Button text="Historial de Compras" onAction="#onNavHistorial"/>
                <Button text="Mi Perfil" onAction="#onNavPerfil" disable="true"
                        style="-fx-background-color: #34495e; -fx-text-fill: white;"/>
                <Button text="Cerrar sesión" onAction="#onCerrarSesion"
                        style="-fx-background-color: #7f8c8d; -fx-text-fill: white;"/>
            </HBox>

            <Label text="Mi Perfil"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        </VBox>
    </top>

    <!-- ═══ CONTENIDO PRINCIPAL ═══ -->
    <center>
        <HBox spacing="24.0">
            <padding><Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/></padding>

            <!-- ── Sección izquierda: Datos personales ── -->
            <VBox spacing="10.0" prefWidth="380.0">
                <Label text="Datos Personales"
                       style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                <Separator/>

                <GridPane hgap="10.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="110.0"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="Nombre:"          GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtNombre"   GridPane.rowIndex="0" GridPane.columnIndex="1"
                               promptText="Nombre completo"/>

                    <Label text="Correo:"          GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtCorreo"   GridPane.rowIndex="1" GridPane.columnIndex="1"
                               promptText="correo@ejemplo.com"/>

                    <Label text="Teléfono:"        GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtTelefono" GridPane.rowIndex="2" GridPane.columnIndex="1"
                               promptText="(+57) 300 000 0000"/>
                </GridPane>

                <Label fx:id="lblMensajePerfil"
                       style="-fx-font-size: 12px;"
                       visible="false" managed="false" wrapText="true"/>

                <Button fx:id="btnGuardarPerfil" text="Guardar Cambios"
                        onAction="#onGuardarPerfilClick"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white;" maxWidth="Infinity"/>
            </VBox>

            <Separator orientation="VERTICAL"/>

            <!-- ── Sección derecha: Medios de Pago ── -->
            <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                <Label text="Medios de Pago Guardados"
                       style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                <Separator/>

                <TableView fx:id="tblMediosPago" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colTitular"  text="Titular"        prefWidth="160.0"/>
                        <TableColumn fx:id="colDigitos"  text="Últimos 4 dígitos" prefWidth="140.0"/>
                    </columns>
                </TableView>

                <!-- Formulario para agregar nuevo medio -->
                <GridPane hgap="10.0" vgap="8.0">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="90.0"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="Titular:"          GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtTitularTarjeta" GridPane.rowIndex="0" GridPane.columnIndex="1"
                               promptText="Nombre en la tarjeta"/>

                    <Label text="Número:"           GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtNumeroTarjeta"  GridPane.rowIndex="1" GridPane.columnIndex="1"
                               promptText="XXXX XXXX XXXX XXXX"/>
                </GridPane>

                <HBox spacing="8.0">
                    <Button fx:id="btnAgregarMedio" text="Agregar Tarjeta"
                            onAction="#onAgregarMedioClick"
                            style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
                    <Button fx:id="btnEliminarMedio" text="Eliminar Seleccionada"
                            onAction="#onEliminarMedioClick"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
                </HBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>