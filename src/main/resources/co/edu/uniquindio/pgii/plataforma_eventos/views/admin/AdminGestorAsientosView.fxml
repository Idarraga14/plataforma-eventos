<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="1000.0" prefHeight="680.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.pgii.plataforma_eventos.ui.controllers.admin.AdminGestorAsientosController">

    <!-- ═══ ENCABEZADO ═══ -->
    <top>
        <VBox style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="12.0" right="16.0" bottom="12.0" left="16.0"/></padding>
            <HBox spacing="6.0" alignment="CENTER_LEFT">
                <Button text="Dashboard"   onAction="#onNavDashboard"/>
                <Button text="Eventos"     onAction="#onNavEventos"/>
                <Button text="Recintos"    onAction="#onNavRecintos"/>
                <Button text="Usuarios"    onAction="#onNavUsuarios"/>
                <Button text="Compras"     onAction="#onNavCompras"/>
                <Button text="Asientos"    onAction="#onNavAsientos" disable="true"
                        style="-fx-background-color: #34495e; -fx-text-fill: white;"/>
                <Button text="Incidencias" onAction="#onNavIncidencias"/>
                <Button text="Cerrar sesión" onAction="#onCerrarSesion"
                        style="-fx-background-color: #7f8c8d; -fx-text-fill: white;"/>
                <padding><Insets bottom="8.0"/></padding>
            </HBox>
            <Label text="Gestor de Asientos por Evento"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <!-- Selector de evento -->
            <HBox spacing="14.0" alignment="CENTER_LEFT">
                <padding><Insets top="10.0"/></padding>
                <Label text="Evento:" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="comboEventos" promptText="Selecciona un evento con asientos…"
                          prefWidth="420.0" onAction="#onEventoSeleccionado"/>
            </HBox>
        </VBox>
    </top>

    <!-- ═══ CONTENIDO: mapa de asientos ═══ -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #f9f9f9;">
            <content>
                <VBox fx:id="panelZonas" spacing="20.0">
                    <padding><Insets top="16.0" right="20.0" bottom="16.0" left="20.0"/></padding>
                    <!-- Las zonas y cuadrículas se generan dinámicamente -->
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <!-- ═══ LEYENDA Y ESTADO ═══ -->
    <bottom>
        <HBox spacing="20.0" alignment="CENTER_LEFT">
            <padding><Insets top="10.0" right="16.0" bottom="10.0" left="16.0"/></padding>
            <Label fx:id="lblEstado" text="Selecciona un evento para ver el mapa de asientos."
                   style="-fx-text-fill: #7f8c8d;"/>
            <HBox spacing="8.0" alignment="CENTER_LEFT">
                <Label text="■" style="-fx-text-fill: #27ae60; -fx-font-size: 16px;"/>
                <Label text="Disponible"/>
                <Label text="■" style="-fx-text-fill: #e67e22; -fx-font-size: 16px;"/>
                <Label text="Bloqueado"/>
                <Label text="■" style="-fx-text-fill: #e74c3c; -fx-font-size: 16px;"/>
                <Label text="Vendido"/>
            </HBox>
        </HBox>
    </bottom>
</BorderPane>
