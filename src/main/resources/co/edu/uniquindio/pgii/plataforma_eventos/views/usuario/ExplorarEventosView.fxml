<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="900.0" prefHeight="620.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.pgii.plataforma_eventos.ui.controllers.usuario.ExplorarEventosController">

    <!-- ═══ PANEL SUPERIOR: Filtros ═══ -->
    <top>
        <VBox spacing="8.0" style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="12.0" right="16.0" bottom="12.0" left="16.0"/></padding>

            <Label text="Explorar Eventos"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <HBox spacing="12.0" alignment="CENTER_LEFT">
                <Label text="Fecha:"/>
                <DatePicker fx:id="dtpFecha" promptText="Seleccione fecha"/>

                <Label text="Ciudad:"/>
                <ComboBox fx:id="comboCiudad" promptText="Todas las ciudades" prefWidth="160.0"/>

                <Label text="Categoría:"/>
                <ComboBox fx:id="comboCategoria" promptText="Todas las categorías" prefWidth="160.0"/>

                <Button fx:id="btnBuscar" text="Buscar" onAction="#onBuscarClick"
                        style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
                <Button fx:id="btnLimpiarFiltros" text="Limpiar" onAction="#onLimpiarFiltrosClick"/>
            </HBox>
        </VBox>
    </top>

    <!-- ═══ PANEL CENTRAL: Tabla de Eventos ═══ -->
    <center>
        <VBox spacing="10.0">
            <padding><Insets top="12.0" right="16.0" bottom="12.0" left="16.0"/></padding>

            <TableView fx:id="tblEventos" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNombre"    text="Nombre"    prefWidth="220.0"/>
                    <TableColumn fx:id="colFecha"     text="Fecha"     prefWidth="140.0"/>
                    <TableColumn fx:id="colCiudad"    text="Ciudad"    prefWidth="120.0"/>
                    <TableColumn fx:id="colCategoria" text="Categoría" prefWidth="120.0"/>
                    <TableColumn fx:id="colEstado"    text="Estado"    prefWidth="100.0"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <!-- ═══ PANEL INFERIOR: Acciones ═══ -->
    <bottom>
        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <padding><Insets top="10.0" right="16.0" bottom="10.0" left="16.0"/></padding>
            <Button fx:id="btnVerDetalle" text="Ver Detalle del Evento"
                    onAction="#onVerDetalleClick"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
        </HBox>
    </bottom>
</BorderPane>