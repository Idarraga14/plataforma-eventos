<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.ColumnConstraints?>

<BorderPane prefWidth="580.0" prefHeight="500.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.pgii.plataforma_eventos.ui.controllers.usuario.PagoController">

    <!-- ═══ ENCABEZADO ═══ -->
    <top>
        <VBox style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="14.0" right="16.0" bottom="14.0" left="16.0"/></padding>
            <Label text="Método de Pago"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        </VBox>
    </top>

    <!-- ═══ CONTENIDO CENTRAL ═══ -->
    <center>
        <VBox spacing="16.0">
            <padding><Insets top="20.0" right="28.0" bottom="20.0" left="28.0"/></padding>

            <!-- Resumen del monto -->
            <HBox spacing="12.0" alignment="CENTER"
                  style="-fx-background-color: #2c3e50; -fx-padding: 14px; -fx-border-radius: 6px;">
                <Label text="Total a pagar:"
                       style="-fx-text-fill: white; -fx-font-size: 16px;"/>
                <Label fx:id="lblTotalAPagar" text="$0"
                       style="-fx-text-fill: #f39c12; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            </HBox>

            <!-- TabPane: tarjeta guardada vs. nueva tarjeta -->
            <TabPane fx:id="tabPanePago" tabClosingPolicy="UNAVAILABLE">

                <!-- Tab 1: Tarjeta guardada -->
                <Tab text="Tarjeta Guardada">
                    <content>
                        <VBox spacing="12.0">
                            <padding><Insets top="16.0" right="10.0" bottom="16.0" left="10.0"/></padding>
                            <Label text="Seleccione un medio de pago guardado:"
                                   style="-fx-font-weight: bold;"/>
                            <ComboBox fx:id="comboMediosPago" maxWidth="Infinity"
                                      promptText="-- Seleccionar tarjeta --"/>
                            <Label fx:id="lblSinTarjetas"
                                   text="No tienes tarjetas guardadas. Usa la pestaña 'Nueva Tarjeta'."
                                   style="-fx-text-fill: #e74c3c;" visible="false" managed="false"
                                   wrapText="true"/>
                        </VBox>
                    </content>
                </Tab>

                <!-- Tab 2: Nueva tarjeta -->
                <Tab text="Nueva Tarjeta">
                    <content>
                        <VBox spacing="10.0">
                            <padding><Insets top="16.0" right="10.0" bottom="16.0" left="10.0"/></padding>
                            <GridPane hgap="10.0" vgap="10.0">
                                <columnConstraints>
                                    <ColumnConstraints prefWidth="120.0"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>

                                <Label text="Titular:"        GridPane.rowIndex="0" GridPane.columnIndex="0"
                                       style="-fx-font-weight: bold;"/>
                                <TextField fx:id="txtTitularNueva" GridPane.rowIndex="0" GridPane.columnIndex="1"
                                           promptText="Nombre en la tarjeta"/>

                                <Label text="Número tarjeta:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                                       style="-fx-font-weight: bold;"/>
                                <TextField fx:id="txtNumTarjeta" GridPane.rowIndex="1" GridPane.columnIndex="1"
                                           promptText="XXXX XXXX XXXX XXXX"/>

                                <Label text="CVV:"            GridPane.rowIndex="2" GridPane.columnIndex="0"
                                       style="-fx-font-weight: bold;"/>
                                <TextField fx:id="txtCvv"     GridPane.rowIndex="2" GridPane.columnIndex="1"
                                           promptText="000" prefWidth="60.0"/>

                                <Label text="Vencimiento:"    GridPane.rowIndex="3" GridPane.columnIndex="0"
                                       style="-fx-font-weight: bold;"/>
                                <TextField fx:id="txtVencimiento" GridPane.rowIndex="3" GridPane.columnIndex="1"
                                           promptText="MM/AA" prefWidth="80.0"/>
                            </GridPane>
                        </VBox>
                    </content>
                </Tab>
            </TabPane>

            <Label fx:id="lblMensajePago"
                   style="-fx-font-size: 12px;"
                   visible="false" managed="false" wrapText="true"/>
        </VBox>
    </center>

    <!-- ═══ PANEL INFERIOR: Acciones ═══ -->
    <bottom>
        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <padding><Insets top="10.0" right="16.0" bottom="10.0" left="16.0"/></padding>
            <Button fx:id="btnVolver" text="← Volver" onAction="#onVolverClick"/>
            <Button fx:id="btnPagar"  text="Confirmar Pago"  onAction="#onPagarClick"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10px 20px;"/>
        </HBox>
    </bottom>
</BorderPane>
