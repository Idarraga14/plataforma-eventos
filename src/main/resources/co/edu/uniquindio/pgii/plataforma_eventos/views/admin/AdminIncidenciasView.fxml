<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="900.0" prefHeight="680.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.pgii.plataforma_eventos.ui.controllers.admin.AdminIncidenciasController">

    <!-- ═══ ENCABEZADO ═══ -->
    <top>
        <VBox style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="12.0" right="16.0" bottom="12.0" left="16.0"/></padding>
            <Label text="Registro de Incidencias"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Registra y consulta incidencias asociadas a eventos, usuarios o compras."
                   style="-fx-text-fill: #7f8c8d;"/>
        </VBox>
    </top>

    <!-- ═══ CONTENIDO CENTRAL ═══ -->
    <center>
        <VBox spacing="0.0">

            <!-- ── Formulario de registro ── -->
            <VBox spacing="12.0" style="-fx-border-color: #dee2e6; -fx-border-width: 0 0 1 0;">
                <padding><Insets top="16.0" right="20.0" bottom="16.0" left="20.0"/></padding>
                <Label text="Nueva Incidencia"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                <GridPane hgap="14.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="130.0"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints prefWidth="130.0"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="Entidad afectada:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                           style="-fx-font-weight: bold;"/>
                    <!-- Opciones del enum IncidenciaEntidadAfectada: EVENTO, USUARIO, COMPRA, ASIENTO -->
                    <ComboBox fx:id="comboEntidadAfectada" GridPane.rowIndex="0" GridPane.columnIndex="1"
                              maxWidth="Infinity" promptText="Seleccionar entidad…"/>

                    <Label text="ID Entidad:"       GridPane.rowIndex="0" GridPane.columnIndex="2"
                           style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtIdEntidad" GridPane.rowIndex="0" GridPane.columnIndex="3"
                               promptText="ID del elemento afectado"/>

                    <Label text="Reportado por:"   GridPane.rowIndex="1" GridPane.columnIndex="0"
                           style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtReportadoPor" GridPane.rowIndex="1" GridPane.columnIndex="1"
                               promptText="Nombre del responsable"/>

                    <Label text="Descripción:"     GridPane.rowIndex="2" GridPane.columnIndex="0"
                           style="-fx-font-weight: bold;"/>
                    <TextArea fx:id="txtDescripcion" GridPane.rowIndex="2" GridPane.columnIndex="1"
                              GridPane.columnSpan="3" prefRowCount="3" wrapText="true"
                              promptText="Describe detalladamente la incidencia…"/>
                </GridPane>

                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                    <Label fx:id="lblMensajeIncidencia" style="-fx-font-size: 12px;"
                           visible="false" managed="false" wrapText="true"/>
                    <Button fx:id="btnLimpiarIncidencia" text="Limpiar"
                            onAction="#onLimpiarIncidenciaClick"/>
                    <Button fx:id="btnRegistrarIncidencia" text="Registrar Incidencia"
                            onAction="#onRegistrarIncidenciaClick"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
                </HBox>
            </VBox>

            <Separator/>

            <!-- ── Histórico de incidencias ── -->
            <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                <padding><Insets top="10.0" right="20.0" bottom="10.0" left="20.0"/></padding>
                <Label text="Histórico de Incidencias"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <TableView fx:id="tblIncidencias" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colFecha"          text="Fecha"           prefWidth="130.0"/>
                        <TableColumn fx:id="colEntidad"        text="Entidad"         prefWidth="110.0"/>
                        <TableColumn fx:id="colIdEntidad"      text="ID Entidad"      prefWidth="100.0"/>
                        <TableColumn fx:id="colReportadoPor"   text="Reportado por"   prefWidth="150.0"/>
                        <TableColumn fx:id="colDescripcion"    text="Descripción"     prefWidth="300.0"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>
