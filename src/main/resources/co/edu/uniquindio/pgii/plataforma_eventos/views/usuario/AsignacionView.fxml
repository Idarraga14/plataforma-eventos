<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="780.0" prefHeight="580.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.pgii.plataforma_eventos.ui.controllers.usuario.AsignacionController">

    <!-- ═══ ENCABEZADO ═══ -->
    <top>
        <VBox style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="14.0" right="16.0" bottom="14.0" left="16.0"/></padding>
            <Label text="Selección de Zona y Asiento"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <HBox spacing="12.0" alignment="CENTER_LEFT">
                <padding><Insets top="10.0"/></padding>
                <Label text="Zona:" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="comboZonas" promptText="Seleccione una zona" prefWidth="260.0"/>
            </HBox>
        </VBox>
    </top>

    <!-- ═══ CONTENIDO CENTRAL ═══ -->
    <center>
        <VBox spacing="16.0">
            <padding><Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/></padding>

            <!-- ── Modo numerado: grilla de asientos ── -->
            <VBox fx:id="panelAsientos" spacing="8.0">
                <Label text="Seleccione su asiento:"
                       style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Label text="[ ESCENARIO ]"
                       style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-padding: 6px; -fx-alignment: center;"
                       maxWidth="Infinity"/>

                <!-- El GridPane se construye dinámicamente en el controller -->
                <GridPane fx:id="gridAsientos" hgap="6.0" vgap="6.0" alignment="CENTER"/>

                <HBox spacing="12.0">
                    <Label text="■" style="-fx-text-fill: #2ecc71;"/> <Label text="Disponible"/>
                    <Label text="■" style="-fx-text-fill: #e74c3c;"/> <Label text="Ocupado"/>
                    <Label text="■" style="-fx-text-fill: #3498db;"/> <Label text="Seleccionado"/>
                </HBox>
            </VBox>

            <Separator/>

            <!-- ── Modo por zona (no numerado): selector de cantidad ── -->
            <HBox fx:id="panelCantidad" spacing="12.0" alignment="CENTER_LEFT">
                <Label text="Cantidad de entradas:"
                       style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                <ComboBox fx:id="comboCantidad" prefWidth="90.0"/>
                <Label text="(máx. 6 por compra)"
                       style="-fx-text-fill: #7f8c8d;"/>
            </HBox>

            <Separator/>

            <!-- Resumen / mensaje de estado -->
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label text="Estado:" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblInfo" text="Seleccione una zona para comenzar."
                       style="-fx-text-fill: #555;"/>
            </HBox>
        </VBox>
    </center>

    <!-- ═══ PANEL INFERIOR: Acciones ═══ -->
    <bottom>
        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <padding><Insets top="10.0" right="16.0" bottom="10.0" left="16.0"/></padding>
            <Button fx:id="btnVolver" text="← Volver" onAction="#onVolverClick"/>
            <Button fx:id="btnContinuar" text="Continuar →" onAction="#onContinuarClick"
                    style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-size: 13px;"/>
        </HBox>
    </bottom>
</BorderPane>
