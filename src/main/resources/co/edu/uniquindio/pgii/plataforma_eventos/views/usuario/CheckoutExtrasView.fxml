<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="560.0" prefHeight="480.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.pgii.plataforma_eventos.ui.controllers.usuario.CheckoutExtrasController">

    <!-- ═══ ENCABEZADO ═══ -->
    <top>
        <VBox style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="14.0" right="16.0" bottom="14.0" left="16.0"/></padding>
            <Label text="Servicios Adicionales"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label fx:id="lblResumen" text="Resumen de compra"
                   style="-fx-text-fill: #7f8c8d;" wrapText="true"/>
            <Label fx:id="lblSubtotal" text="Subtotal Entradas: $0"
                   style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-padding: 6 0 0 0;"/>
        </VBox>
    </top>

    <!-- ═══ CONTENIDO CENTRAL ═══ -->
    <center>
        <VBox spacing="18.0">
            <padding><Insets top="24.0" right="30.0" bottom="24.0" left="30.0"/></padding>

            <!-- Extra 1: Pase VIP -->
            <HBox spacing="14.0" alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-border-color: #dfe6e9; -fx-border-width: 1;">
                <padding><Insets top="14.0" right="14.0" bottom="14.0" left="14.0"/></padding>
                <CheckBox fx:id="chkVip"/>
                <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                    <Label text="Pase VIP"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Label text="Acceso prioritario, zona exclusiva y beneficios especiales."
                           style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" wrapText="true"/>
                </VBox>
                <Label text="+ $50.000"
                       style="-fx-text-fill: #27ae60; -fx-font-weight: bold;"/>
            </HBox>

            <!-- Extra 2: Seguro de Cancelacion -->
            <HBox spacing="14.0" alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-border-color: #dfe6e9; -fx-border-width: 1;">
                <padding><Insets top="14.0" right="14.0" bottom="14.0" left="14.0"/></padding>
                <CheckBox fx:id="chkSeguro"/>
                <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                    <Label text="Seguro de Cancelacion"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Label text="Reembolso total si cancelas con 48 h de anticipacion."
                           style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" wrapText="true"/>
                </VBox>
                <Label text="+ $15.000"
                       style="-fx-text-fill: #27ae60; -fx-font-weight: bold;"/>
            </HBox>

            <!-- Extra 3: Parqueadero -->
            <HBox spacing="14.0" alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-border-color: #dfe6e9; -fx-border-width: 1;">
                <padding><Insets top="14.0" right="14.0" bottom="14.0" left="14.0"/></padding>
                <CheckBox fx:id="chkParqueadero"/>
                <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                    <Label text="Parqueadero"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Label text="Cupo de parqueo cubierto y seguro en el recinto."
                           style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;" wrapText="true"/>
                </VBox>
                <Label text="+ $20.000"
                       style="-fx-text-fill: #27ae60; -fx-font-weight: bold;"/>
            </HBox>

            <Separator/>

            <!-- Resumen de precio -->
            <HBox spacing="10.0" alignment="CENTER_RIGHT">
                <Label fx:id="lblTotal" text="Total a Pagar: $0"
                       style="-fx-font-size: 16px; -fx-text-fill: #e67e22; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </center>

    <!-- ═══ PANEL INFERIOR: Acciones ═══ -->
    <bottom>
        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <padding><Insets top="10.0" right="16.0" bottom="10.0" left="16.0"/></padding>
            <Button fx:id="btnCancelar"  text="Cancelar"   onAction="#onCancelarClick"/>
            <Button fx:id="btnIrAPagar"  text="Ir a Pagar" onAction="#onIrAPagarClick"
                    style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-size: 13px;"/>
        </HBox>
    </bottom>
</BorderPane>
