<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="1100.0" prefHeight="720.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.pgii.plataforma_eventos.ui.controllers.admin.AdminDashboardController">

    <!-- ═══ ENCABEZADO ═══ -->
    <top>
        <VBox style="-fx-background-color: #2c3e50;">
            <padding><Insets top="16.0" right="20.0" bottom="16.0" left="20.0"/></padding>
            <HBox spacing="20.0" alignment="CENTER_LEFT">
                <Label text="Panel de Administración"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="|" style="-fx-text-fill: #7f8c8d;"/>
                <Label text="Dashboard en tiempo real"
                       style="-fx-font-size: 13px; -fx-text-fill: #bdc3c7;"/>
            </HBox>

            <!-- Tarjetas de resumen rápido -->
            <HBox spacing="16.0">
                <padding><Insets top="12.0"/></padding>
                <VBox style="-fx-background-color: #34495e; -fx-padding: 10;" prefWidth="180.0">
                    <Label text="Eventos Activos" style="-fx-text-fill: #bdc3c7; -fx-font-size: 11px;"/>
                    <Label fx:id="lblEventosActivos" text="0"
                           style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                </VBox>
                <VBox style="-fx-background-color: #34495e; -fx-padding: 10;" prefWidth="180.0">
                    <Label text="Ventas del Mes" style="-fx-text-fill: #bdc3c7; -fx-font-size: 11px;"/>
                    <Label fx:id="lblVentasMes" text="text"
                           style="-fx-text-fill: #f39c12; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                </VBox>
                <VBox style="-fx-background-color: #34495e; -fx-padding: 10;" prefWidth="180.0">
                    <Label text="Usuarios Registrados" style="-fx-text-fill: #bdc3c7; -fx-font-size: 11px;"/>
                    <Label fx:id="lblTotalUsuarios" text="0"
                           style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                </VBox>
                <VBox style="-fx-background-color: #34495e; -fx-padding: 10;" prefWidth="180.0">
                    <Label text="Incidencias Abiertas" style="-fx-text-fill: #bdc3c7; -fx-font-size: 11px;"/>
                    <Label fx:id="lblIncidenciasAbiertas" text="0"
                           style="-fx-text-fill: #e74c3c; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- ═══ CONTENIDO CENTRAL: Gráficas ═══ -->
    <center>
        <VBox spacing="16.0">
            <padding><Insets top="16.0" right="20.0" bottom="16.0" left="20.0"/></padding>

            <!-- Fila 1: LineChart (ocupa todo el ancho) -->
            <Label text="Ventas por Período"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <LineChart fx:id="lineChartVentas" prefHeight="220.0">
                <xAxis><CategoryAxis label="Período"/></xAxis>
                <yAxis><NumberAxis label="Ingresos ($)"/></yAxis>
            </LineChart>

            <Separator/>

            <!-- Fila 2: PieChart + BarChart lado a lado -->
            <HBox spacing="16.0">
                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                    <Label text="Ocupación por Zona"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <PieChart fx:id="pieChartOcupacion" prefHeight="240.0"/>
                </VBox>
                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                    <Label text="Ingresos por Servicio Adicional"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <BarChart fx:id="barChartServicios" prefHeight="240.0">
                        <xAxis><CategoryAxis label="Servicio"/></xAxis>
                        <yAxis><NumberAxis label="Ingresos ($)"/></yAxis>
                    </BarChart>
                </VBox>
            </HBox>
        </VBox>
    </center>

    <!-- ═══ PANEL INFERIOR ═══ -->
    <bottom>
        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <padding><Insets top="10.0" right="20.0" bottom="10.0" left="20.0"/></padding>
            <Label fx:id="lblUltimaActualizacion" text="Última actualización: —"
                   style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;"/>
            <Button fx:id="btnRefrescar" text="Refrescar datos" onAction="#onRefrescarClick"
                    style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
        </HBox>
    </bottom>
</BorderPane>