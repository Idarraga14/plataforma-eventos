<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="1000.0" prefHeight="720.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.pgii.plataforma_eventos.ui.controllers.admin.AdminEventosController">

    <!-- ═══ ENCABEZADO ═══ -->
    <top>
        <VBox style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="12.0" right="16.0" bottom="12.0" left="16.0"/></padding>
            <Label text="Gestión de Eventos"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        </VBox>
    </top>

    <!-- ═══ CONTENIDO CENTRAL: Master-Detail ═══ -->
    <center>
        <VBox spacing="0.0">

            <!-- ── SECCIÓN SUPERIOR: Formulario (Maestro) ── -->
            <VBox spacing="10.0" style="-fx-border-color: #dee2e6; -fx-border-width: 0 0 1 0;">
                <padding><Insets top="14.0" right="20.0" bottom="14.0" left="20.0"/></padding>
                <Label fx:id="lblModoFormulario" text="Nuevo Evento"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                <GridPane hgap="14.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="110.0"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints prefWidth="110.0"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="Nombre:"      GridPane.rowIndex="0" GridPane.columnIndex="0"
                           style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtNombreEvento" GridPane.rowIndex="0" GridPane.columnIndex="1"
                               promptText="Nombre del evento"/>

                    <Label text="Categoría:"   GridPane.rowIndex="0" GridPane.columnIndex="2"
                           style="-fx-font-weight: bold;"/>
                    <ComboBox fx:id="comboCategoria" GridPane.rowIndex="0" GridPane.columnIndex="3"
                              maxWidth="Infinity" promptText="Seleccionar…"/>

                    <Label text="Fecha:"       GridPane.rowIndex="1" GridPane.columnIndex="0"
                           style="-fx-font-weight: bold;"/>
                    <DatePicker fx:id="dtpFechaEvento" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Ciudad:"      GridPane.rowIndex="1" GridPane.columnIndex="2"
                           style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtCiudad" GridPane.rowIndex="1" GridPane.columnIndex="3"
                               promptText="Ciudad"/>

                    <Label text="Recinto:"     GridPane.rowIndex="2" GridPane.columnIndex="0"
                           style="-fx-font-weight: bold;"/>
                    <ComboBox fx:id="comboRecinto" GridPane.rowIndex="2" GridPane.columnIndex="1"
                              maxWidth="Infinity" promptText="Seleccionar recinto…"/>

                    <Label text="Estado:"      GridPane.rowIndex="2" GridPane.columnIndex="2"
                           style="-fx-font-weight: bold;"/>
                    <!-- Estados: BORRADOR, PUBLICADO, PAUSADO, CANCELADO, FINALIZADO -->
                    <ComboBox fx:id="comboEstado" GridPane.rowIndex="2" GridPane.columnIndex="3"
                              maxWidth="Infinity" promptText="Cambiar estado…"/>

                    <Label text="Descripción:" GridPane.rowIndex="3" GridPane.columnIndex="0"
                           style="-fx-font-weight: bold;"/>
                    <TextArea fx:id="txtDescripcion" GridPane.rowIndex="3" GridPane.columnIndex="1"
                              GridPane.columnSpan="3" prefRowCount="3" wrapText="true"
                              promptText="Descripción del evento…"/>
                </GridPane>

                <!-- Botones del formulario -->
                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                    <Button fx:id="btnLimpiarFormulario" text="Limpiar"
                            onAction="#onLimpiarFormularioClick"/>
                    <Button fx:id="btnGuardarEvento" text="Guardar Evento"
                            onAction="#onGuardarEventoClick"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
                </HBox>
            </VBox>

            <Separator/>

            <!-- ── SECCIÓN INFERIOR: Tabla (Detalle) ── -->
            <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                <padding><Insets top="10.0" right="20.0" bottom="10.0" left="20.0"/></padding>
                <Label text="Lista de Eventos"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <TableView fx:id="tblEventos" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNombre"    text="Nombre"    prefWidth="220.0"/>
                        <TableColumn fx:id="colCategoria" text="Categoría" prefWidth="120.0"/>
                        <TableColumn fx:id="colFecha"     text="Fecha"     prefWidth="130.0"/>
                        <TableColumn fx:id="colCiudad"    text="Ciudad"    prefWidth="120.0"/>
                        <TableColumn fx:id="colEstado"    text="Estado"    prefWidth="110.0"/>
                    </columns>
                </TableView>
                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                    <Button fx:id="btnEditarEvento" text="Editar Seleccionado"
                            onAction="#onEditarEventoClick"
                            style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
                    <Button fx:id="btnEliminarEvento" text="Eliminar"
                            onAction="#onEliminarEventoClick"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>